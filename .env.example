# ============================================================
# StyleForge environment template
# Copy this file to `.env` and fill in real values.
# NEVER commit the real `.env` file (it is gitignored).
# ============================================================

# --- Stepfun (阶跃星辰) API ---
# Get from https://platform.stepfun.com/  (China) or https://platform.stepfun.ai/ (global)
STEPFUN_API_KEY=replace_with_your_stepfun_key
STEPFUN_BASE_URL=https://api.stepfun.com/v1
STEPFUN_VLM_MODEL=step-3.7-flash
STEPFUN_TEXT_MODEL=step-2-mini

# --- NVIDIA developer API (build.nvidia.com cloud NIM fallback / model routing demo) ---
# Get from https://build.nvidia.com/  (sign in → API keys)
NVIDIA_API_KEY=replace_with_your_nvidia_key
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5
# CP-013 local<->cloud reasoning router: local-first (default) | cloud-first | local-only
ROUTING_STRATEGY=local-first

# --- Hugging Face (NeMo LoRA fine-tuning leg: download base models / datasets) ---
# Get from https://huggingface.co/settings/tokens
HF_TOKEN=replace_with_your_hf_token
# Workshop keeps HF offline with a pre-populated cache; flip to 0 only when pulling:
HF_HUB_OFFLINE=1

# --- Telegram bot (NemoClaw always-on remote access demo) ---
# Create via @BotFather -> /newbot
TELEGRAM_BOT_TOKEN=replace_with_your_telegram_bot_token

# --- NVIDIA local stack (DGX Spark) ---
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_API_KEY=ollama-local
# Dev: nemotron-3-nano:30b (pulled from registry). Demo: nemotron-3-super:120b.
OLLAMA_REASONING_MODEL=nemotron-3-nano:30b
OLLAMA_LIGHT_MODEL=qwen3.6:35b
COMFYUI_HOST=http://127.0.0.1:8200

# --- OpenClaw agent platform ---
# Path is deployment-specific (workshop bundle location). Set to your bundle's openclaw-home.
OPENCLAW_HOME=/home/nvidia/build_a_claw_workshop/openclaw-home
OPENCLAW_PORT=9000  # workshop notebook defaults to 3030; this Spark's gateway binds 9000 (check `ss -ltn`)

# --- App ---
APP_PORT=8000
FRONTEND_PORT=5173
LOG_LEVEL=INFO

# --- Security & token budget (see references/design/07-security-and-tokens.md) ---
MAX_UPLOAD_MB=10
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Comma-separated Telegram chat IDs allowed to trigger runs (empty = bot disabled)
TELEGRAM_ALLOWED_CHAT_IDS=
MAX_TOTAL_VLM_CALLS=25
MAX_TOTAL_RENDERS=20
RUN_TIMEOUT_S=600
NO_CLOUD_VISION=0
VLM_IMAGE_DETAIL_FIRST=high
VLM_IMAGE_DETAIL_RECHECK=low
RUN_ID_REGEX=^[A-Za-z0-9_-]{1,64}$

# Workshop script for CUDA-dirty restart (absolute path; empty disables).
COMFYUI_CTL_SCRIPT=

# CP-014: optional FLUX LoRA adapter (ComfyUI LoraLoader). Filename relative to
# ComfyUI's models/loras/ dir; empty disables LoRA (default non-LoRA path).
LORA_ADAPTER=
LORA_STRENGTH=1.0
